public class HW5RadixSort {
    public static void sort(int[] values) {
        if (values == null || values.length < 2) {
            return;
        }

        int max = values[0];
        for (int i = 1; i < values.length; i++) {
            if (values[i] > max) {
                max = values[i];
            }
        }

        @SuppressWarnings("unchecked")
        HW5ArrayQueue<Integer>[] buckets = (HW5ArrayQueue<Integer>[]) new HW5ArrayQueue[10];
        for (int i = 0; i < buckets.length; i++) {
            buckets[i] = new HW5ArrayQueue<>();
        }

        // one pass for ones, tens, hundreds, etc.
        for (int place = 1; max / place > 0; place *= 10) {
            for (int value : values) {
                if (value < 0) {
                    throw new IllegalArgumentException("Radix sort only supports non-negative integers.");
                }

                int digit = (value / place) % 10;
                buckets[digit].enqueue(value);
            }

            int index = 0;
            for (HW5ArrayQueue<Integer> bucket : buckets) {
                while (!bucket.isEmpty()) {
                    values[index++] = bucket.dequeue();
                }
            }
        }
    }
}
