public class HW5ArrayQueue<T> {
    // circular array queue
    private static final int DEFAULT_CAPACITY = 10;

    private T[] data;
    private int front;
    private int size;

    @SuppressWarnings("unchecked")
    public HW5ArrayQueue() {
        data = (T[]) new Object[DEFAULT_CAPACITY];
    }

    public void enqueue(T item) {
        if (size == data.length) {
            resize();
        }
        int rear = (front + size) % data.length;
        data[rear] = item;
        size++;
    }

    public T dequeue() {
        if (size == 0) {
            return null;
        }

        T item = data[front];
        data[front] = null;
        front = (front + 1) % data.length;
        size--;
        return item;
    }

    public T peek() {
        if (size == 0) {
            return null;
        }
        return data[front];
    }

    public boolean isEmpty() {
        return size == 0;
    }

    public int size() {
        return size;
    }

    @SuppressWarnings("unchecked")
    public void clear() {
        data = (T[]) new Object[DEFAULT_CAPACITY];
        front = 0;
        size = 0;
    }

    @SuppressWarnings("unchecked")
    private void resize() {
        T[] expanded = (T[]) new Object[data.length * 2];
        for (int i = 0; i < size; i++) {
            expanded[i] = data[(front + i) % data.length];
        }
        data = expanded;
        front = 0;
    }
}
